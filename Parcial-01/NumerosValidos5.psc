Algoritmo NumerosValidos
	
	definir numEnter Como Entero
	
	Escribir "Ingrese un número entero entre el 1 y el 10: "
	Leer numEnter
	
	Mientras numEnter >= 1 Y numEnter <= 10 Hacer
		
		Escribir "Número válido. " 
		Escribir "Ingrese otro numero entero entre 1 y 10: "
		Leer numEnter
		
	FinMientras
	
	Escribir "Número inválido "
	Escribir "Fin del programa "
		
FinAlgoritmo
