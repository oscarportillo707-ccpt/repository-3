Algoritmo CalificaciónNota
	
	Definir nota Como Entero 
	
	Escribir "Escriba la nota del estudiante de 0 a 10: "
	Leer nota
	
	Si nota == 5 Entonces
		Escribir "En recuperación "
	FinSi
	
	Si nota >= 6 Entonces
		Escribir "El estudiante ha aprobado"
	FinSi 
		
	Si nota <= 4 Entonces
		Escribir "El estudiante ha reprobado"
	FinSi
	
FinAlgoritmo
