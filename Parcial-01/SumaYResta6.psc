Algoritmo SumaYResta
	
	Definir num1, num2, suma, resta Como Real  
	
	Escribir "Ingrese el primer número a operar: "
	Leer num1
	
	Escribir "Ingrese el segundo número a operar: "
	Leer num2
	
	suma = num1 + num2
	resta = num1 - num2
	
	Escribir "La suma es: ", suma
	Escribir "La resta es: ", resta
	
FinAlgoritmo
